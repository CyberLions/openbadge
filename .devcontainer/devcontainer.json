{
  "name": "OpenBadge Platform",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/openbadge",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "forwardPorts": [3000, 5173, 5432, 1025, 8025],
  "portsAttributes": {
    "3000": { "label": "Backend API", "onAutoForward": "notify" },
    "5173": { "label": "Vue Frontend", "onAutoForward": "openBrowser" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" },
    "1025": { "label": "MailHog SMTP", "onAutoForward": "silent" },
    "8025": { "label": "MailHog UI", "onAutoForward": "notify" }
  },
  "containerEnv": {
    "DATABASE_URL": "postgresql://openbadge:openbadge_dev@localhost:5432/openbadge",
    "SMTP_HOST": "localhost",
    "SMTP_PORT": "1025",
    "SMTP_SECURE": "false",
    "APP_URL": "http://localhost:3000",
    "FRONTEND_URL": "http://localhost:5173",
    "NODE_ENV": "development"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Vue.volar",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "Prisma.prisma",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
      }
    }
  },
  "shutdownAction": "stopCompose"
}
