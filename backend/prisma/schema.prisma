generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Issuer {
  id          String       @id @default(uuid())
  name        String
  url         String
  email       String
  description              String?
  imageUrl                 String?
  linkedInOrganizationName String?
  createdAt                DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  badgeClasses BadgeClass[]
  signingKeys  SigningKey[]
}

model SigningKey {
  id            String   @id @default(uuid())
  issuerId      String
  issuer        Issuer   @relation(fields: [issuerId], references: [id], onDelete: Cascade)
  publicKeyPem  String
  privateKeyPem String
  algorithm     String   @default("EdDSA")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([issuerId])
}

model BadgeClass {
  id          String      @id @default(uuid())
  issuerId    String
  issuer      Issuer      @relation(fields: [issuerId], references: [id], onDelete: Cascade)
  name        String
  description String
  imageUrl    String
  criteriaUrl String?
  criteriaNarrative String?
  tags        String[]    @default([])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  assertions  Assertion[]
  invites     BadgeInvite[]

  @@index([issuerId])
}

model Assertion {
  id              String    @id @default(uuid())
  badgeClassId    String
  badgeClass      BadgeClass @relation(fields: [badgeClassId], references: [id], onDelete: Cascade)
  recipientEmail  String
  recipientName   String?
  recipientHashed Boolean   @default(true)
  salt            String
  issuedOn        DateTime  @default(now())
  expires         DateTime?
  revoked         Boolean   @default(false)
  revokedReason   String?
  evidenceUrl     String?
  evidenceNarrative String?
  jws             String?
  emailSent       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([badgeClassId])
  @@index([recipientEmail])
}

model Upload {
  id          String   @id @default(uuid())
  filename    String   @unique
  mimeType    String
  size        Int
  data        Bytes
  createdAt   DateTime @default(now())
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String
  keyHash     String   @unique
  keyPrefix   String
  scopes      String[] @default(["*"])
  active      Boolean  @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BadgeInvite {
  id             String     @id @default(uuid())
  token          String     @unique
  badgeClassId   String
  badgeClass     BadgeClass @relation(fields: [badgeClassId], references: [id], onDelete: Cascade)
  recipientEmail String?
  recipientName  String?
  status         String     @default("pending") // pending | claimed | expired
  expiresAt      DateTime
  assertionId    String?    // set when claimed and badge is issued
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([token])
  @@index([badgeClassId])
}

model LocalUser {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditEvent {
  id          String   @id @default(uuid())
  action      String
  actor       String
  actorType   String   @default("user")
  targetType  String?
  targetId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([actor])
  @@index([createdAt])
}
